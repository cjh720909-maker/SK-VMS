  C_ADDRESS   String? @db.VarChar(100)
  CB_DIV_CUST String? @db.VarChar(40)
  C_TEL       String? @db.VarChar(20)
  C_MEMO      String? @db.VarChar(200)

  @@map("NPS_t_customer")
}

