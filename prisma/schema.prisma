model NPS_t_balju {
  B_IDX            Int       @id @default(autoincrement())
  CB_IDX           Int?
  CB_IDX_ORI       Int?
  B_DATE           String?   @db.VarChar(10)
  B_C_NAME_ORI     String?   @db.VarChar(80)
  B_C_NAME         String    @db.VarChar(80)
  B_C_CODE         String?   @db.VarChar(40)
  B_C_PAN_NAME_ORI String?   @db.VarChar(80)
  B_C_PAN_NAME     String?   @db.VarChar(80)
  B_NAP_DIV_ORI    String?   @db.VarChar(20)
  B_NAP_DIV        String?   @db.VarChar(20)
  B_P_NO           String?   @db.VarChar(20)
  B_P_NAME         String?   @db.VarChar(80)
  B_DAN            Int       @default(0)
  B_VAT_DIV        String?   @db.VarChar(10)
  B_KG             Decimal   @default(0.00) @db.Decimal(11, 2)
  B_IN_QTY         Decimal   @default(0.0) @db.Decimal(11, 1)
  B_QTY            Int       @default(0)
  B_PKG            String?   @db.VarChar(10)
  B_NAP_NO         String?   @db.VarChar(20)
  B_ORDER_NO       String?   @db.VarChar(20)
  B_MEMO           String?   @db.VarChar(80)
  B_EDT_E_NAME     String?   @db.VarChar(20)
  C_NAME           String?   @db.VarChar(50)
  B_EDT_DATETIME   DateTime? @db.Timestamp(0)
  CB_NAME          String?   @db.VarChar(80)
  CB_DRIVER        String?   @db.VarChar(40)
  CB_DIV_CUST      String?   @db.VarChar(20)
  CB_ADDRESS       String?   @db.VarChar(200)
  CB_PHONE         String?   @db.VarChar(40)
  CB_HP            String?   @db.VarChar(40)
  CB_BIND          String?   @db.VarChar(80)
  CB_CODE          String?   @db.VarChar(40)
  O_IDX            Int?
  B_EX_SEQ         String?   @default("0") @db.VarChar(20)
  O_QTY            Int       @default(0)
  B_IN_CONFIRM     String    @default("N") @db.Char(1)
  B_PICK_DONE      String    @default("N") @db.Char(1)
  B_GUM_DONE       String    @default("N") @db.Char(1)
  B_GUM_DATE       DateTime? @db.Timestamp(0)
  B_GUM_E_NAME     String?   @db.VarChar(20)
  B_QTY_DAS_STCOK  Int       @default(0)
  B_ORDER_DATE     String?   @db.VarChar(10)
  B_BARCODE        String?   @db.VarChar(20)
  B_STATE          String?   @db.VarChar(20)
  B_MAKER          String?   @db.VarChar(40)


  @@index([B_DATE, CB_IDX, B_P_NO], map: "NPS_B_DATE_IDX")
  @@index([B_P_NO, C_NAME], map: "NPS_B_P_NO_IDX")
  @@index([O_IDX], map: "NPS_O_IDX_IDX")

  @@map("NPS_t_balju")
}

model NPS_t_customer {
